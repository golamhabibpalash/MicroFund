{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Serve Angular",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "start", "--", "--port=4200", "--host=0.0.0.0"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "name": "Angular: Serve",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "start"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "name": "Angular: Debug",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "start", "--", "--open=false", "--host=0.0.0.0"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "NODE_OPTIONS": "--inspect-brk"
            },
            "skipFiles": ["<node_internals>/**"]
        }
    ],
    "compounds": []
}